                              <Value>=Sum(Lookup(Fields!NumCompte.Value, Fields!NumCompte.Value, Fields!Solde.Value, "DataSet2") - Fields!SommeEntree.Value + Fields!SommeSortie.Value)</Value>
                              <Style>
